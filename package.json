{
  "name": "@hmfw/html-to-pdf",
  "version": "1.3.0",
  "type": "module",
  "description": "框架无关的 HTML 转 PDF 库：读取真实 DOM 布局，用 pdf-lib 生成可选中的矢量 PDF，默认支持中文（思源黑体）。",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build && tsc -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "pdf",
    "html-to-pdf",
    "dom-to-pdf",
    "pdf-lib",
    "export-pdf",
    "vector-pdf",
    "framework-agnostic",
    "chinese-font",
    "source-han-sans"
  ],
  "author": "",
  "license": "MIT",
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14",
    "Edge >= 90",
    "not IE 11"
  ],
  "dependencies": {
    "@pdfme/pdf-lib": "^6.1.10",
    "fontkit": "^2.0.2",
    "opentype.js": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.5",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
